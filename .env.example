# ============ LLM providers (LiteLLM) ============
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
# Clients talk to the local LiteLLM proxy with this placeholder key
LITELLM_API_KEY=sk-litellm

# ============ n8n ============
N8N_DB_PASS=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars-min
# HMAC key used by the orchestrator to sign webhook calls (PLAN_FINAL §9.1.5)
N8N_WEBHOOK_SECRET=change-me-long-random

# ============ SearXNG ============
SEARXNG_SECRET=change-me-random

# ============ Panel ============
# Comma-separated Tailscale logins allowed in (header Tailscale-User-Login)
PANEL_ALLOWED_USERS=josea.castillodiez@gmail.com
# Second factor for admin actions inside the panel
PANEL_PASSWORD=change-me

# ============ Audio (orchestrator) ============
# Leave empty for system default. List devices: make list-audio
AUDIO_INPUT_INDEX=
AUDIO_OUTPUT_INDEX=

# ============ Vision ============
# GID of the host 'render' group: getent group render
RENDER_GID=989

# ============ Misc ============
TZ=Europe/Madrid
